<?xml version="1.0" encoding="UTF-8"?>
<!-- IAR Project Connection File -->

<iarProjectConnection version="1.2" name="I2C TMP" oneShot="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="IarProjectConnection_1.2.xsd">

    <device>
        <name>CC2755R10</name>
    </device>

    <asmIncludePath>
        <path>$PROJ_DIR$</path>
    </asmIncludePath>

    <includePath>
        <path>$PROJ_DIR$</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/tfm_s/build/cc27xx/production_full/Release/export/tfm/inc</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source/third_party/tfm/config</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source/third_party/tfm/interface/include</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source/third_party/tfm/secure_fw/include</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source/third_party/psa_crypto/include</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source/third_party/mbedtls/include</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source/third_party/mbedtls/ti</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source/third_party/mbedtls/ti/port</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/kernel/nortos</path>
        <path>$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/kernel/nortos/posix</path>
    </includePath>

    <defines>
        <define>MBEDTLS_CONFIG_FILE=&lt;configs/config-hsm.h&gt;</define>
        <define>MBEDTLS_PSA_CRYPTO_CONFIG_FILE=&lt;configs/config-psa-crypto-hsm.h&gt;</define>
    </defines>

    <extraOptions>
        <args>
            <arg>-f$PROJ_DIR$/ti_utils_build_compiler.opt</arg>
            <arg>--silent</arg>
            <arg>-e</arg>
            <arg>--aeabi</arg>
            <arg>--thumb</arg>
            <arg>--diag_suppress=Pa050</arg>
        </args>
    </extraOptions>

    <linkerFile>
        <override>true</override>
        <path>$PROJ_DIR$/lpf3_nortos.icf</path>
    </linkerFile>

    <linkerExtraOptions>
        <args>
            <arg>-L$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source</arg>
            <arg>-L$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/tfm_s</arg>
            <arg>--diag_suppress=Li065</arg>
            <arg>-L$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/kernel/nortos</arg>
            <arg>-f$PROJ_DIR$/ti_utils_build_linker.cmd.genlibs</arg>
            <arg>--silent</arg>
        </args>
    </linkerExtraOptions>

    <customBuildTools>
        <customBuildTool atRoot="true" name="SysConfig"> <!-- Custom build tool for entire project-->
            <fileExtensions>.syscfg</fileExtensions>
            <command>$SYSCONFIG_ROOT$/sysconfig_cli.bat -o $PROJ_DIR$ -s "$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/.metadata/product.json" --compiler iar $FILE_PATH$</command>
            <output>
                <path>SysConfig_Generated_Files.ipcf</path>
            </output>
            <hasPrio>true</hasPrio> <!-- true: run this tool before all other tools-->
        </customBuildTool>
    </customBuildTools>

    <heaps>
        <heap> <!-- If omitted, id="0" -->
            <size>0</size>
        </heap>
        <heap id="1">
            <size>0</size>
        </heap>
    </heaps>
    <stacks>
        <stack> <!-- If omitted, id="0" -->
            <size>512</size>
        </stack>
    </stacks>


    <files>
        <path reference="$PROJ_DIR$/Board.html">$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/source/ti/boards/LP_EM_CC2755R10_BG/Board.html</path>
        <path copyTo="$PROJ_DIR$/i2ctmp.c">$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/examples/nortos/LP_EM_CC2755R10_BG/drivers/i2ctmp/i2ctmp.c</path>
        <path copyTo="$PROJ_DIR$/i2ctmp.syscfg">$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/examples/nortos/LP_EM_CC2755R10_BG/drivers/i2ctmp/i2ctmp.syscfg</path>
        <path copyTo="$PROJ_DIR$/lpf3_nortos.icf">$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/examples/nortos/LP_EM_CC2755R10_BG/drivers/i2ctmp/iar/lpf3_nortos.icf</path>
        <path copyTo="$PROJ_DIR$/main_nortos.c">$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/examples/nortos/LP_EM_CC2755R10_BG/drivers/i2ctmp/main_nortos.c</path>
        <path copyTo="$PROJ_DIR$/README.html">$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/examples/nortos/LP_EM_CC2755R10_BG/drivers/i2ctmp/README.html</path>
        <path copyTo="$PROJ_DIR$/README.md">$SIMPLELINK_LOWPOWER_F3_SDK_INSTALL_DIR$/examples/nortos/LP_EM_CC2755R10_BG/drivers/i2ctmp/README.md</path>
    </files>
</iarProjectConnection>